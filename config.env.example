# Camera Configuration
# Camera type: "opencv" for USB/webcam, "picamera" for Raspberry Pi camera
CAMERA_TYPE=opencv

# Left Camera Configuration
LEFT_CAMERA_ID=0

# Right Camera Configuration  
RIGHT_CAMERA_ID=1

# Camera Resolution
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Model Configuration
MODEL_PATH=models/yolov11n.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45
# Input image size for YOLO inference (smaller = faster on Raspberry Pi 5)
# Recommended: 320 for Pi 5, 640 for desktop/server
YOLO_IMGSZ=320

# Temperature Sensor Configuration
TEMP_SENSOR_DEVICE_ID=28-00000xxxxxxx

# LED Configuration
LED_GPIO_PIN=18
LED_COUNT=60
LED_BRIGHTNESS=255

# Storage Configuration
# Set to an external SSD or USB mount path on Raspberry Pi 5
# Example: /mnt/ssd/anilag or /media/pi/MySSD/anilag
# Leave empty to use the default application directory
SCAN_STORAGE_PATH=
DB_STORAGE_PATH=

# Logging Configuration
LOG_FILE=logs/detection_log.csv

# Image Capture Configuration
# Threshold for high weevil count to trigger image capture
HIGH_WEEVIL_THRESHOLD=5
# Cooldown period in seconds between image captures
IMAGE_CAPTURE_COOLDOWN=30

# Email Notification Configuration
EMAIL_ENABLED=true
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=recipient_email@gmail.com
